import java.util.*;
import java.security.MessageDigest;

class User {
    String username;
    String passwordHash;

    public User(String username, String passwordHash) {
        this.username = username;
        this.passwordHash = passwordHash;
    }
}

public class AuthSystem {

    static HashMap<String, User> users = new HashMap<>();
    static Scanner sc = new Scanner(System.in);

    // Хэш функциясы (SHA-256)
    public static String hashPassword(String password) {
        try {
            MessageDigest md = MessageDigest.getInstance("SHA-256");
            byte[] hash = md.digest(password.getBytes());
            StringBuilder hex = new StringBuilder();

            for (byte b : hash) {
                hex.append(String.format("%02x", b));
            }

            return hex.toString();
        } catch (Exception e) {
            return null;
        }
    }

    // Тіркелу
    public static void register() {
        System.out.print("Username: ");
        String username = sc.next();
        System.out.print("Password: ");
        String password = sc.next();

        String hashed = hashPassword(password);
        users.put(username, new User(username, hashed));

        System.out.println("Тіркелу сәтті!");
    }

    // Кіру
    public static void login() {
        System.out.print("Username: ");
        String username = sc.next();
        System.out.print("Password: ");
        String password = sc.next();

        if (users.containsKey(username)) {
            String hashed = hashPassword(password);

            if (users.get(username).passwordHash.equals(hashed)) {
                System.out.println("Кіру сәтті!");
            } else {
                System.out.println("Қате пароль!");
            }
        } else {
            System.out.println("Пайдаланушы табылмады!");
        }
    }

    public static void main(String[] args) {

        while (true) {
            System.out.println("\n1. Register");
            System.out.println("2. Login");
            System.out.println("3. Exit");
            System.out.print("Таңдау: ");

            int choice = sc.nextInt();

            switch (choice) {
                case 1: register(); break;
                case 2: login(); break;
                case 3: return;
                default: System.out.println("Қате!");
            }
        }
    }
}
